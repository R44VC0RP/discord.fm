# --- Discord ---
DISCORD_TOKEN=your-bot-token
DISCORD_GUILD_ID=123456789012345678
# Optional: auto-join this voice channel on boot (otherwise use /radio join)
DISCORD_VOICE_CHANNEL_ID=

# --- Station identity ---
STATION_NAME=anomaly.fm
STATION_DESCRIPTION=live from the anomaly
STATION_GENRE=talk
STATION_TZ=America/New_York

# --- Sound ---
# am = mono, band-limited, compressed, saturated, static bed + carrier fade
# clean = untouched stereo passthrough
RADIO_PRESET=am
RADIO_BITRATE=96k

# AM character knobs (only used when RADIO_PRESET=am)
AM_LOWCUT_HZ=300
AM_HIGHCUT_HZ=3800
AM_NOISE_LEVEL=0.004
AM_FLUTTER_HZ=0.3
AM_FLUTTER_DEPTH=0.08

# Voice-gated crackle: dust/pops on speech only (applies in any preset)
CRACKLE_LEVEL=0.3      # 0 disables
CRACKLE_DENSITY=10     # avg pops/sec while someone talks

# --- Background music bed (loops when channel is empty, ducks when occupied) ---
# Path inside the container (docker-compose mounts ./music). "off" disables.
MUSIC_FILE=/music/background.mp3
MUSIC_GAIN=0.9
MUSIC_DUCK_GAIN=0.08
MUSIC_FADE_DOWN_MS=1200
MUSIC_FADE_UP_MS=3000

# --- Activity feed (RSS + JSON served by icecast at /feed/) ---
# "off" disables.
FEED_DIR=/feed
FEED_MAX_ITEMS=50

# --- Icecast ---
# ICECAST_HOST is overridden to "icecast" inside docker compose; set it only
# for running the bot outside compose (e.g. local dev against localhost).
ICECAST_HOST=icecast
ICECAST_PORT=8000
ICECAST_MOUNT=/radio
ICECAST_SOURCE_PASSWORD=change-me
ICECAST_ADMIN_PASSWORD=change-me-too
ICECAST_RELAY_PASSWORD=
ICECAST_MAX_CLIENTS=250

# --- Public endpoint (used by the caddy tls profile + icecast hostname) ---
STREAM_DOMAIN=stream.example.com

# --- Session recordings (mp3 stream-copy while humans are in the channel) ---
RECORDING_STOP_DELAY_S=0     # finalize when the last human leaves; nonzero retains a grace period
RECORDINGS_MAX_GB=10         # retention cap; oldest sessions deleted first

# --- Reruns (replay recordings while the channel is empty) ---
RERUN_AUTO=true              # rotate the archive when the queue is empty
RERUN_AFTER_LIVE_MIN=35      # quiet time after live ends before any rerun
RERUN_GAP_MIN=35             # music-bed gap between consecutive reruns
# Rotation: oldest unaired session first; nothing repeats until the whole
# archive has aired. State persists in feed/rerun-state.json.

# --- Control room (admin panel at ADMIN_DOMAIN via the caddy host-router) ---
ADMIN_DOMAIN=fm.anoma.ly
# Generate: docker run --rm caddy:2 caddy hash-password --plaintext 'yourpassword'
ADMIN_PASSWORD_HASH=

# --- TV encoder (docker compose --profile tv up -d) ---
# YouTube: Live Control Room -> stream key. X: Premium + Media Studio Producer
# -> Sources -> create RTMP source (URL + key). Leave empty to disable each.
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_KEY=
X_RTMP_URL=
X_STREAM_KEY=
# X has NO documented duration cap for immediately-started broadcasts, and a
# feed restart risks ending the broadcast (no API exists to create a new one).
# Leave empty unless testing proves a real cap; then set e.g. 02:00.
X_RESTART_AT=
X_RESTART_TZ=America/New_York
TV_VIDEO_BITRATE=2500k
TV_AUDIO_BITRATE=128k
TV_FPS=24

# --- Hourly time checks (air only when nobody is live) ---
# AI blurb (Claude via opencode zen) voiced by ElevenLabs; always states
# Eastern + Pacific time, may mention the current rerun/listeners/SF weather.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ZEN_API_KEY=
ZEN_MODEL=claude-haiku-4-5
ZEN_URL=https://opencode.ai/zen/v1/messages

# --- Hotline (Twilio voicemail line -> control room -> on air) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
CALL_WEBHOOK_BASE=https://anomaly.fm

# --- Voice session hygiene ---
VOICE_REFRESH_HOURS=3         # reconnect while channel is empty; 0 disables

# --- YouTube live chat -> Discord bridge (both required to enable) ---
# API key: console.cloud.google.com -> enable "YouTube Data API v3" -> API key.
# Video ID: the watch?v= id of the 24/7 broadcast (changes if it restarts).
# Bot needs Send Messages permission in the voice channel.
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_ID=
YT_CHAT_POLL_S=45             # 45s keeps a 24/7 bridge inside default quota

# --- Durable automation (private compose network; opt-in profile) ---
# Generate a long random value for production. This token is shared only by
# trusted bot/admin/automation services and must remain in .env.
AUTOMATION_INTERNAL_TOKEN=
AUTOMATION_PLAYOUT_ENABLED=false  # later bot cutover; false preserves all current audio paths
# Internal only; compose mounts generated assets read-only into the bot.
AUTOMATION_INTERNAL_URL=http://automation:8092
AUTOMATION_CROSSFADE_MS=3000
AUTOMATION_DJ_ENABLED=false
AUTOMATION_DJ_SHADOW=false
AUTOMATION_DJ_FAKE_PROVIDER_ENABLED=false # local integration test only; never production
# Separate least-privilege credential accepted only by the seven DJ endpoints.
AUTOMATION_DJ_TOOL_TOKEN=
AUTOMATION_HOTLINE_ENABLED=false
AUTOMATION_HOTLINE_IMPORT_ENABLED=false
AUTOMATION_GENERATION_ENABLED=false
AUTOMATION_AI_ARCHIVE_ENABLED=false
AUTOMATION_IMPORT_MUSIC_ON_START=false
AUTOMATION_RERUN_POLL_MS=5000
AUTOMATION_LOW_CUES=12
AUTOMATION_HIGH_CUES=24
AUTOMATION_LOW_HORIZON_MIN=45
AUTOMATION_TARGET_HORIZON_MIN=90
AUTOMATION_MAX_HORIZON_MIN=120
# Comma-separated, operator-reviewed deterministic screen. Empty is fail-safe
# only while hotline automation remains disabled.
AUTOMATION_HOTLINE_BADWORDS=
# Optional deterministic speech-output screen (comma-separated).
AUTOMATION_SPEECH_BADWORDS=

# Private pinned OpenCode DJ server. Generate a separate long random password.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
# Exact provider/model. Existing ZEN_API_KEY above is mapped to OPENCODE_API_KEY
# only inside the private OpenCode service.
AUTOMATION_DJ_MODEL=opencode/claude-haiku-4-5
AUTOMATION_DJ_TIMEOUT_MS=60000
AUTOMATION_DJ_POLL_MS=15000
AUTOMATION_DJ_DAILY_TOOL_LIMIT=200
AUTOMATION_DJ_DAILY_MODEL_TOKEN_LIMIT=200000

# Ahead-of-air speech generation uses the existing ElevenLabs key/voice above.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
AUTOMATION_GENERATION_POLL_MS=2000
AUTOMATION_GENERATED_MAX_BYTES=10000000
AUTOMATION_GENERATED_BUDGET_BYTES=2147483648
AUTOMATION_TTS_DAILY_CHARACTER_LIMIT=20000
